{
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "cacheFrom": [
      "ghcr.io/opendevicepartnership/odp-platform-qemu-sbsa/devcontainer:main",
      "ghcr.io/opendevicepartnership/odp-platform-qemu-sbsa/devcontainer:latest"
    ]
  },
  "forwardPorts": [
    5005, // For general use. EXDI, TCP Serial, etc.
    5006,
    5007,
    5008,
    5900 // VNC
  ],
  "runArgs": [
    "--device=/dev/ttyACM0:/dev/ttyQEMU0"
  ],
  "mounts": [],
  "containerEnv": {
    "SCCACHE_DIR": "${containerWorkspaceFolder}/.sccache"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "bierner.markdown-mermaid"
      ]
    }
  }
}
